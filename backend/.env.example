# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trading_club

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-here-min-32-chars-required-for-security
JWT_REFRESH_SECRET=your-refresh-secret-key-here-min-32-chars-required
JWT_EXPIRY=30d
JWT_REFRESH_EXPIRY=90d

# OTP/SMS
OTP_EXPIRY_MINUTES=10

# S3 Storage (Wasabi or AWS)
S3_ENDPOINT=s3.wasabisys.com
S3_BUCKET=trading-club-payments
S3_ACCESS_KEY_ID=your-wasabi-access-key
S3_SECRET_ACCESS_KEY=your-wasabi-secret-key
S3_REGION=us-east-1

# OneSignal (Push Notifications)
ONESIGNAL_APP_ID=your-app-id
ONESIGNAL_API_KEY=your-api-key

# Admin
ADMIN_PHONE=+1234567890

# Security
WEBHOOK_SECRET=your-webhook-secret-min-32-chars
CORS_ORIGIN=http://localhost:8081,http://localhost:3000
