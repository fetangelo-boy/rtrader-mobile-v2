{
  "name": "trading-club-mobile",
  "version": "1.0.0",
  "description": "Trading Club Mobile App - React Native / Expo",
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "dev": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "axios": "^1.7.7",
    "expo": "^51.0.0",
    "expo-constants": "^16.0.0",
    "expo-device": "^6.0.0",
    "expo-font": "^12.0.0",
    "expo-image": "^2.0.0",
    "expo-image-picker": "^15.0.0",
    "expo-notifications": "^0.28.0",
    "expo-router": "^3.0.0",
    "expo-screen-orientation": "^7.0.0",
    "expo-secure-store": "^13.0.0",
    "expo-splash-screen": "^0.28.0",
    "expo-status-bar": "^2.0.0",
    "react": "^19.0.0",
    "react-native": "^0.75.0",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^4.0.0",
    "react-native-safe-area-context": "^4.0.0",
    "react-native-screens": "^4.0.0",
    "react-native-svg": "^14.0.0",
    "react-native-web": "~0.20.0",
    "socket.io-client": "^4.7.2",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "expo": {
    "name": "Trading Club",
    "slug": "trading-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trading Club to access your photos",
          "cameraPermission": "Allow Trading Club to access your camera"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ]
  }
}
